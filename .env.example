# =============================================================================
# VPS CHR — Environment Variables
# Copy ke .env dan isi semua nilai sebelum docker compose up
# =============================================================================

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Dapatkan dari: Zero Trust Dashboard → Networks → Tunnels → Create → Docker
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# ── PiHole ────────────────────────────────────────────────────────────────────
# Password untuk admin panel PiHole (http://10.10.0.1:8080/admin)
PIHOLE_PASSWORD=ganti_dengan_password_kuat

# ── MQTT Credentials ─────────────────────────────────────────────────────────
# Generate password file dulu: bash mosquitto/setup-passwd.sh
MQTT_USERNAME=browser-agent
MQTT_PASSWORD=ganti_dengan_password_kuat

# ── JWT Secret (untuk autentikasi future) ────────────────────────────────────
# Generate: openssl rand -hex 64
JWT_SECRET=your_jwt_secret_here

# ── gRPC Server ───────────────────────────────────────────────────────────────
# URL full-tool-browser di VPS Scraper (via WireGuard)
# Default: http://10.10.0.2:8080 (sudah di-hardcode di compose, override jika perlu)
# BROWSER_URL=http://10.10.0.2:8080
